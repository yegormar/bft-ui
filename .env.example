# Public env vars (Vite exposes only VITE_* to the client).
# Copy to .env and set values. No defaults are applied in code; missing required vars cause dev/build to exit. Do not commit .env.

# Required in development: API port for /api proxy (must match bft-api PORT).
VITE_API_PORT=3001

# Required in production build. In dev with proxy, can be empty or unset.
VITE_API_BASE_URL=http://localhost:3001

# Required in production build. Application display name.
VITE_APP_NAME=BFT UI
